---
---

<div id="toc-bar">
  <div class="toc-inner">
    <button id="toc-toggle" aria-expanded="false">
      <span id="toc-title"></span>
      <span id="toc-sep" class="toc-sep">›</span>
      <span id="toc-current"></span>
      <svg id="toc-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
      </svg>
    </button>
    <nav id="toc-list" aria-label="文章目錄"></nav>
  </div>
</div>

<style>
  #toc-bar {
    position: fixed;
    inset-inline: 0;
    top: 0;
    z-index: 39;
    background: rgba(255 255 255 / 0.96);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(0 0 0 / 0.07);
  }

  :global(.dark) #toc-bar {
    background: rgba(15 23 42 / 0.96);
    border-bottom-color: rgba(255 255 255 / 0.07);
  }

  .toc-inner {
    max-width: 48rem; /* 配合文章 max-w-3xl */
    margin-inline: auto;
    padding-inline: 1.5rem;
  }

  #toc-toggle {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    padding-block: 0.55rem;
    width: 100%;
    background: none;
    border: none;
    cursor: pointer;
    color: inherit;
    font-size: 0.85rem;
    min-width: 0;
  }

  #toc-title {
    font-weight: 600;
    opacity: 0.55;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 45%;
    flex-shrink: 0;
  }

  .toc-sep {
    opacity: 0.35;
    flex-shrink: 0;
  }

  #toc-current {
    font-weight: 500;
    color: #3b82f6;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex: 1;
    min-width: 0;
  }

  :global(.dark) #toc-current {
    color: #60a5fa;
  }

  #toc-arrow {
    width: 0.9rem;
    height: 0.9rem;
    margin-left: auto;
    flex-shrink: 0;
    opacity: 0.4;
    transition: transform 0.2s ease;
  }

  #toc-arrow.open {
    transform: rotate(180deg);
  }

  /* 收合時隱藏 sep 和 current */
  #toc-bar.collapsed #toc-sep,
  #toc-bar.collapsed #toc-current {
    display: none;
  }

  #toc-list {
    display: none;
    flex-direction: column;
    gap: 0.1rem;
    padding-block: 0.4rem 0.65rem;
    max-height: 55vh;
    overflow-y: auto;
  }

  #toc-list.open {
    display: flex;
  }

  #toc-list a {
    display: block;
    padding: 0.3rem 0.75rem;
    border-radius: 0.4rem;
    font-size: 0.875rem;
    text-decoration: none;
    color: inherit;
    opacity: 0.6;
    transition: opacity 0.15s, background 0.15s;
  }

  #toc-list a:hover {
    opacity: 1;
    background: rgba(59 130 246 / 0.08);
  }

  #toc-list a.active {
    opacity: 1;
    color: #3b82f6;
    background: rgba(59 130 246 / 0.1);
    font-weight: 500;
  }

  :global(.dark) #toc-list a.active {
    color: #60a5fa;
    background: rgba(96 165 250 / 0.12);
  }
</style>

<script>
  function initTOC() {
    const bar     = document.getElementById('toc-bar');
    const toggle  = document.getElementById('toc-toggle');
    const titleEl = document.getElementById('toc-title');
    const sepEl   = document.getElementById('toc-sep');
    const currEl  = document.getElementById('toc-current');
    const list    = document.getElementById('toc-list');
    const arrow   = document.getElementById('toc-arrow');

    if (!bar) return;

    // ── 1. TOC 位置：跟著 sticky Header ──
    const header = document.getElementById('header') ?? document.querySelector('header');

    function syncTop() {
      const bottom = header?.getBoundingClientRect().bottom ?? 0;
      bar!.style.top = Math.max(0, bottom) + 'px';
    }
    syncTop();
    window.addEventListener('scroll', syncTop, { passive: true });
    window.addEventListener('resize', syncTop, { passive: true });

    // ── 2. 找 prose 容器和 H2 ──
    const prose = document.querySelector('article .prose, article [class*="prose"]');
    if (!prose) { bar.style.display = 'none'; return; }

    const h2s = Array.from(prose.querySelectorAll('h2'));
    if (h2s.length === 0) { bar.style.display = 'none'; return; }

    // ── 3. 文章大標題（H1）──
    const h1Text = document.querySelector('article h1')?.textContent?.trim()
                ?? document.title.split(/[—|·]/)[0].trim();
    if (titleEl) titleEl.textContent = h1Text ?? '';

    // ── 4. 確保 H2 有 id ──
    h2s.forEach((h, i) => { if (!h.id) h.id = `h2-${i}`; });

    // ── 5. 產生連結 ──
    if (list) {
      list.innerHTML = h2s
        .map(h => `<a href="#${h.id}" data-id="${h.id}">${h.textContent?.trim()}</a>`)
        .join('');
    }

    // ── 6. 初始狀態：沒讀到任何 H2 前，隱藏 sep & current ──
    bar.classList.add('collapsed');

    // ── 7. 展開 / 收合 ──
    let isOpen = false;

    toggle?.addEventListener('click', () => {
      isOpen = !isOpen;
      list?.classList.toggle('open', isOpen);
      arrow?.classList.toggle('open', isOpen);
      toggle.setAttribute('aria-expanded', String(isOpen));
    });

    list?.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        isOpen = false;
        list!.classList.remove('open');
        arrow?.classList.remove('open');
        toggle?.setAttribute('aria-expanded', 'false');
      });
    });

    // ── 8. IntersectionObserver 追蹤目前 H2 ──
    let currentId = '';

    const observer = new IntersectionObserver(entries => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          currentId = entry.target.id;
        }
      }

      const found = h2s.find(h => h.id === currentId);
      if (found && currEl) {
        currEl.textContent = found.textContent?.trim() ?? '';
        bar.classList.remove('collapsed'); // 顯示 sep & current
      }

      // active 樣式
      list?.querySelectorAll('a').forEach(a => {
        a.classList.toggle('active', (a as HTMLAnchorElement).dataset.id === currentId);
      });
    }, {
      // H2 進入畫面上方 15% 時觸發，離開下方 75% 時結束
      rootMargin: '-15% 0px -75% 0px',
      threshold: 0,
    });

    h2s.forEach(h => observer.observe(h));
  }

  // View Transitions 相容（每次換頁重新初始化）
  document.addEventListener('astro:page-load', initTOC);
  initTOC();
</script>
